# DIANAFARM GROUP v285 production backend
# Copy to .env.production.local manually OR run: npm run env:generate
# Replace every value before production deployment.

DFG_NODE_ENV=production
DFG_PORT=8080
DFG_PUBLIC_ORIGIN=https://your-domain.com
DFG_ADMIN_PASSWORD=replace-with-a-long-private-password-min-16-chars
DFG_SESSION_SECRET=replace-with-64-plus-random-characters
DFG_STORAGE_DIR=./data
DFG_MAX_JSON_BYTES=5242880
DFG_MAX_MEDIA_BYTES=8388608
DFG_LEAD_WEBHOOK_URL=
